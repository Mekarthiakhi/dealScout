PORT=5000
NODE_ENV=development

# ============================================================================
# GOOGLE CUSTOM SEARCH API CONFIGURATION
# ============================================================================
# 
# Step 1: Get Google API Key
# - Go to: https://console.cloud.google.com/apis/credentials
# - Create a new project (e.g., "DealScout")
# - Enable "Custom Search API"
# - Click "Create Credentials" → "API Key"
# - Copy the API Key below
#
# Step 2: Get Search Engine ID (CX)
# - Go to: https://cse.google.com/cse/
# - Click "Create"
# - Add sites: amazon.com flipkart.com ebay.com walmart.com newegg.com
# - Click "Create"
# - Go to "Setup" → "Basics"
# - Find "Search Engine ID" and copy it below
#
# IMPORTANT: Never commit real API keys to GitHub!
# Always use .gitignore to protect .env files
#
# FREE TIER: 100 queries/day
# PAID TIER: $5 per 1,000 queries (up to 10,000/day)
#
# ============================================================================

# Your Google API Key (get from Google Cloud Console)
# Format: AIza...
GOOGLE_API_KEY=AIzaSyExample_ReplaceWithYourRealKeyFromGoogleCloud

# Your Custom Search Engine ID (get from cse.google.com)
# Format: d1b2c3d4e5f6g7h8i9j0
GOOGLE_SEARCH_ENGINE_ID=d1b2c3d4e5f6g7h8i9j0

# ============================================================================
# OPTIONAL: Other API Keys (for future integrations)
# ============================================================================
AMAZON_API_KEY=optional
FLIPKART_API_KEY=optional
EBAY_API_KEY=optional
WALMART_API_KEY=optional

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Set to 'production' when deploying
NODE_ENV=development

# Set to 'true' to enable verbose logging
DEBUG=false

# Cache expiration time (in minutes)
CACHE_EXPIRATION=5
